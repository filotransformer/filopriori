###############################################################################
# Filo-Priori — .gitignore
#
# Purpose: expose ONLY the artifacts needed for IEEE TSE reviewers to replicate
# the paper. Author-only material, intermediate cache, large/regeneratable
# outputs, and licensed third-party content are excluded.
#
# Public repository: https://github.com/filotransformer/filopriori.git
###############################################################################

# -----------------------------------------------------------------------------
# Python build / bytecode
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/
.python-version

# -----------------------------------------------------------------------------
# Test, coverage, type-checking caches
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Jupyter / notebook artifacts
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# IDE / editor configuration (user-specific)
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.~*

# -----------------------------------------------------------------------------
# OS-specific junk
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
.fuse_hidden*

# -----------------------------------------------------------------------------
# WSL / Windows interop artifacts
# -----------------------------------------------------------------------------
*Zone.Identifier
*:Zone.Identifier

# -----------------------------------------------------------------------------
# AI-agent local configuration (author-only, not for reviewers)
# -----------------------------------------------------------------------------
.claude/
.gemini/
.cursor/
.aider*
CLAUDE.md
GEMINI.md
AGENTS.md

# -----------------------------------------------------------------------------
# Author-only documentation / media (not part of the scientific artifact)
# -----------------------------------------------------------------------------
docs/press/
docs/DIAGRAM_PROMPT.md

# Reference PDFs of third-party papers (copyright protected, not redistributable)
reference/

# -----------------------------------------------------------------------------
# Datasets (too large for Git, partially proprietary). Reviewers obtain data
# via the instructions in datasets/*/README.md. READMEs are tracked below.
# -----------------------------------------------------------------------------
datasets/01_industry/*
datasets/02_rtptorrent/raw/
datasets/02_rtptorrent/processed/
datasets/02_rtptorrent/processed_ranking/
!datasets/01_industry/README.md
!datasets/02_rtptorrent/README.md

# -----------------------------------------------------------------------------
# Intermediate cache (regenerated by the pipeline; >70 GB locally)
# -----------------------------------------------------------------------------
cache/
*.pkl
*.npz
**/embeddings/*.npy
**/embeddings/*.npz

# -----------------------------------------------------------------------------
# Internal experiment logs (author debugging, contain local paths)
# -----------------------------------------------------------------------------
logs/
*.log
results/**/run_log.txt
results/**/tmux-buffer.txt

# -----------------------------------------------------------------------------
# Archived / deprecated experiment scripts (NOT used in the paper)
# -----------------------------------------------------------------------------
experiments/archived/
_archive/

# -----------------------------------------------------------------------------
# Results: keep summary CSV/JSON for verification; drop large or regeneratable
# artifacts (trained weights, per-test rankings, embedding caches).
# -----------------------------------------------------------------------------
results/**/best_model.pt
results/**/*.pt
results/**/*.pth
results/**/*.ckpt
results/**/prioritized_test_cases.csv
results/**/prioritized_test_cases_*.csv
results/**/predictions_*.csv

# -----------------------------------------------------------------------------
# LaTeX build artifacts
# -----------------------------------------------------------------------------
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.lof
paper/*.lot
paper/*.log
paper/*.nav
paper/*.out
paper/*.snm
paper/*.synctex.gz
paper/*.toc
paper/*.vrb
paper/sections/*.aux
paper/figures/*.aux
paper/
paper/*

# -----------------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig
~*
tmp/
scratch/

# -----------------------------------------------------------------------------
# Secrets / credentials (defense in depth — none are expected in this repo)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

